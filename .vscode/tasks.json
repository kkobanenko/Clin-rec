{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "UI Stack Up",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"docker compose up -d"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "UI Stack Down",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"docker compose down"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "UI Stack Status",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"docker compose ps"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "UI Stack Health",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"curl -fsS http://127.0.0.1:8000/health && echo && curl -I http://127.0.0.1:8501"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "UI Stack Logs",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"docker compose logs --tail=80 app streamlit worker"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Structural Smoke",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				".venv/bin/python scripts/e2e_smoke.py --mode structural"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Quality Smoke",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				".venv/bin/python scripts/e2e_smoke.py --mode quality"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Release Ready Check",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"RUNTIME_PROFILE=docker-compose-only bash scripts/release_ready_check.sh"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "Release Late-Stage Rerun",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"RUNTIME_PROFILE=docker-compose-only SKIP_STRUCTURAL_SMOKE=1 SKIP_QUALITY_SMOKE=1 bash scripts/release_ready_check.sh"
			],
			"isBackground": false,
			"group": "test"
		}
	]
}