# Database
CRIN_DATABASE_URL=postgresql+asyncpg://crplatform:crplatform@localhost:5433/crplatform
CRIN_DATABASE_URL_SYNC=postgresql://crplatform:crplatform@localhost:5433/crplatform

# Redis
CRIN_REDIS_URL=redis://localhost:6380/0

# S3 / MinIO
CRIN_S3_ENDPOINT_URL=http://localhost:9010
CRIN_S3_ACCESS_KEY=minioadmin
CRIN_S3_SECRET_KEY=minioadmin
CRIN_S3_BUCKET=cr-artifacts
CRIN_S3_REGION=us-east-1

# App
CRIN_APP_ENV=development
CRIN_APP_DEBUG=true
CRIN_APP_HOST=0.0.0.0
CRIN_APP_PORT=8000
# Smoke с API из docker compose (хост): CRIN_SMOKE_BASE_URL=http://127.0.0.1:8000
CRIN_LOG_LEVEL=INFO

# Celery
CRIN_CELERY_BROKER_URL=redis://localhost:6380/0
CRIN_CELERY_RESULT_BACKEND=redis://localhost:6380/1

# Discovery
CRIN_RUBRICATOR_BASE_URL=https://cr.minzdrav.gov.ru
CRIN_RUBRICATOR_LIST_PATH=clin-rec
CRIN_RUBRICATOR_LIST_FALLBACK_PATH=clin_recomend
CRIN_RUBRICATOR_VIEW_PATH=clin-rec/view
CRIN_RUBRICATOR_PDF_PATH=clin-rec/pdf
CRIN_RUBRICATOR_API_BASE_URL=https://apicr.minzdrav.gov.ru/api.ashx
CRIN_RUBRICATOR_API_LIST_OP=GetJsonClinrecsFilterV2
CRIN_RUBRICATOR_API_PAGE_SIZE=100
CRIN_RUBRICATOR_API_REQUEST_DELAY=1.0
CRIN_RUBRICATOR_API_USER_AGENT=ClinRecPlatform/1.0 (+https://github.com/kkobanenko/Clin-rec)
CRIN_DISCOVERY_CONCURRENCY=2
CRIN_DISCOVERY_REQUEST_DELAY=2.0

# Sentry (optional)
CRIN_SENTRY_DSN=

# Streamlit
CRIN_STREAMLIT_PORT=8501
